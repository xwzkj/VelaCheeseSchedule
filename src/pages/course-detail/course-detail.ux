</style>

<script>
import router from "@system.router"
import storage from "@system.storage"
import { engine, init, startTimers, stopTimers, getScheduleToday } from "../../common/scheduleEngine"

const TIME_REX = /^(\d{1,2})[：:](\d{1,2})[-~ ]+(\d{1,2})[：:](\d{1,2})$/

function getMinutesNow(offset) {
  const now = new Date()
  return now.getHours() * 60 + now.getMinutes() + (offset / 60)
}

function parseTime(time) {
  const m = TIME_REX.exec(time)
  if (!m) return null
  return {
    start: parseInt(m[1]) * 60 + parseInt(m[2]),
    end: parseInt(m[3]) * 60 + parseInt(m[4])
  }
}

function clamp(value, min, max) {
  return Math.max(min, Math.min(max, value))
}

export default {
  protected: {
    scheduleId: 0,
    dayKey: "",
    lessonIndex: 0
  },

  private: {
    name: "",
    time: "",
    active: 0,
    loaded: false,
    currentTime: "",
    dateLabel: "",
    progressPercent: 0,
    remainText: "",
    _timer: null
  },

  async onInit() {
    if (!engine.inited) {
      await init(storage)
    }
    this.scheduleId = parseInt(this.scheduleId, 10) || 0
    this.dayKey = this.dayKey || ""
    this.lessonIndex = parseInt(this.lessonIndex, 10) || 0
    this.loadLesson()
  },

  onShow() {
    if (this._timer) {
      clearInterval(this._timer)
      this._timer = null
    }
    startTimers()
    const tryLoad = () => {
      this.loadLesson()
      this.refreshDisplay()
      if (this.time && !this.loaded) {
        this.loaded = true
      }
    }
    this._timer = setInterval(tryLoad, 1000)
    setTimeout(tryLoad, 200)
  },

  onHide() {
    if (this._timer) {
      clearInterval(this._timer)
      this._timer = null
    }
    stopTimers()
  },

  onDestroy() {
    if (this._timer) {
      clearInterval(this._timer)
      this._timer = null
    }
    stopTimers()
  },

  onSwipe(e) {
    if (e && e.direction === "right") {
      router.back()
    }
  },

  loadLesson() {
    const daySchedule = engine.schedule[this.scheduleId] && engine.schedule[this.scheduleId][this.dayKey]
    if (!daySchedule) {
      return
    }
    const lessons = getScheduleToday(
      engine.schedule,
      this.scheduleId,
      this.dayKey,
      engine.scheduleOverride
    )
    const lesson = lessons[this.lessonIndex]
    if (lesson) {
      this.name = lesson.name || ""
      this.time = lesson.time || ""
    }
    const rawLesson = daySchedule.lessons[this.lessonIndex]
    if (rawLesson) {
      this.active = parseInt(rawLesson.active, 10) || 0
    }
  },

  refreshDisplay() {
    const now = new Date()
    this.currentTime =
      String(now.getHours()).padStart(2, "0") + ":" + String(now.getMinutes()).padStart(2, "0")
    this.dateLabel = now.getMonth() + 1 + "/" + now.getDate()

    const timeInfo = parseTime(this.time)
    if (!timeInfo) {
      this.progressPercent = 0
      this.remainText = ""
      return
    }

    const nowMinutes = getMinutesNow(engine.setting.timeOffset || 0)
    let percent = 0
    let remain = 0
    let remainText = ""

    if (this.active === 2) {
      let passed = nowMinutes - timeInfo.start
      if (passed < 0) passed += 1440
      const duration = timeInfo.end - timeInfo.start
      const totalDuration = duration > 0 ? duration : duration + 1440
      percent = Math.round((passed / totalDuration) * 100)
      let remainMinutes = timeInfo.end - nowMinutes
      if (remainMinutes < 0) remainMinutes += 1440
      remain = remainMinutes
      remainText = "还剩" + remain + "分钟下课"
    } else if (this.active === 1) {
      percent = 0
      let remainMinutes = timeInfo.start - nowMinutes
      if (remainMinutes < 0) remainMinutes += 1440
      remain = remainMinutes
      remainText = remain + "分钟后上课"
    } else {
      percent = 0
      remainText = ""
    }

    this.progressPercent = clamp(percent, 0, 100)
    this.remainText = remainText
  }
}
</script>
