  color: #ffffff;
  text-align: center;
}

/* 窄屏/跑道屏适配：宽度 <= 150dp 时使用更紧凑布局（336px 宽屏约 168dp，212px 窄屏约 106dp） */
@media (max-width: 150) {
  .content-area {
    padding: 0 16px;
  }

  .course-card {
    padding: 16px;
    border-radius: 12px;
  }

  .course-name {
    font-size: 22px;
  }

  .status-badge {
    font-size: 12px;
    padding: 2px 6px;
    border-radius: 6px;
    margin-left: 6px;
  }

  .course-time {
    font-size: 16px;
    margin-top: 8px;
  }

  .progress-section {
    margin-top: 12px;
  }

  .progress-track {
    height: 6px;
  }

  .progress-fill {
    height: 6px;
  }

  .progress-text {
    font-size: 14px;
    margin-left: 8px;
  }

  .card-divider {
    margin-top: 12px;
  }

  .info-row {
    justify-content: center;
    margin-top: 12px;
  }

  .info-label {
    display: none;
  }

  .info-value {
    font-size: 16px;
    text-align: center;
  }

  .remain-section {
    margin-top: 12px;
  }

  .remain-text {
    font-size: 16px;
  }
