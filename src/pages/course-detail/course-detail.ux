<template>
  <div class="page-container" onswipe="onSwipe">
    <div if="{{!loaded}}" class="loading-wrap">
      <text class="loading-text">加载中...</text>
    </div>
    <div else class="content-area">
      <div class="top-section">
        <text class="time-display">{{ currentTime }}</text>
        <text class="date-display">{{ dateLabel }}</text>
      </div>
      <div class="course-card">
        <div class="card-header">
          <text class="course-name">{{ name }}</text>
          <text if="{{active === 2}}" class="status-badge status-badge--active">上课中</text>
          <text elif="{{active === 1}}" class="status-badge status-badge--upcoming">即将上课</text>
          <text else class="status-badge status-badge--inactive">非活跃课程</text>
        </div>
        <text class="course-time">{{ time }}</text>
        <div class="progress-section">
          <div class="progress-track">
            <div class="progress-fill" style="width: {{ progressPercent }}%"></div>
          </div>
          <text class="progress-text">{{ progressPercent }}%</text>
        </div>
        <div class="info-row">
          <text class="info-label">教室</text>
          <text class="info-value">北楼二层A-101室</text>
        </div>
        <div if="{{active !== 0}}" class="card-divider"></div>
        <div if="{{remainText}}" class="remain-section">
          <text class="remain-text">{{ remainText }}</text>
        </div>
      </div>
    </div>
  </div>
</template>

<style>
